@startuml agents_vacuum
title Agentes AIMA – Mundo de la aspiradora (agents.py)

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor DarkSlateGray
    ArrowColor DarkSlateGray
}
skinparam packageStyle Rectangle
skinparam shadowing false

' -------------------------------------------------------
' Jerarquía de objetos (Things)
' -------------------------------------------------------

class Thing {
    +__repr__() : str
    +is_alive() : bool
    +show_state()
    +display(canvas, x, y, w, h)
}

class Agent {
    +alive : bool = True
    +bump : bool = False
    +holding : list
    +performance : int = 0
    +program : callable
    +__init__(program=None)
    +can_grab(thing) : bool
}

class Dirt
class Obstacle
class Wall

Thing     <|-- Agent
Thing     <|-- Dirt
Thing     <|-- Obstacle
Obstacle  <|-- Wall

' -------------------------------------------------------
' Jerarquía de entornos
' -------------------------------------------------------

abstract class Environment {
    +things : list
    +agents : list
    +{abstract} percept(agent)
    +{abstract} execute_action(agent, action)
    +default_location(thing)
    +exogenous_change()
    +is_done() : bool
    +step()
    +run(steps=1000)
    +add_thing(thing, location)
    +delete_thing(thing)
    +list_things_at(location, tclass) : list
    +some_things_at(location, tclass) : bool
}

class TrivialVacuumEnvironment {
    +status : dict
    +percept(agent) : tuple
    +execute_action(agent, action)
    +default_location(thing)
    ..
    Dos ubicaciones fijas: loc_A, loc_B
    Rendimiento: +10 limpiar, -1 mover
}

class XYEnvironment {
    +width : int
    +height : int
    +observers : list
    +percept(agent) : list
    +execute_action(agent, action)
    +move_to(thing, destination) : bool
    +add_walls()
    +is_inbounds(location) : bool
    +random_location_inbounds() : tuple
}

class VacuumEnvironment {
    +percept(agent) : tuple
    +execute_action(agent, action)
    +thing_classes() : list
    ..
    Grilla NxN con paredes
    Rendimiento: +100 limpiar, -1 turno
}

class GraphicEnvironment {
    +grid : BlockGrid
    +colors : dict
    +run(steps, delay)
    +reveal()
    +draw_world()
}

Environment      <|-- TrivialVacuumEnvironment
Environment      <|-- XYEnvironment
XYEnvironment    <|-- VacuumEnvironment
XYEnvironment    <|-- GraphicEnvironment

Environment "1" o-- "0..*" Thing : contains

VacuumEnvironment o-- Dirt : perceives/removes
VacuumEnvironment o-- Wall : bounded by

' -------------------------------------------------------
' Programas de agente – funciones fábrica
' -------------------------------------------------------

package "Programas de agente (factory functions)" {

    class RandomVacuumAgent <<factory>> {
        +create() : Agent
        ..
        Elige al azar entre:
        Right | Left | Suck | NoOp
    }

    class TableDrivenVacuumAgent <<factory>> {
        +create() : Agent
        ..
        Tabla: secuencia de percepts -> acción
        (inmanejable para entornos grandes)
    }

    class ReflexVacuumAgent <<factory>> {
        +create() : Agent
        ..
        if Dirty  -> Suck
        if loc==A -> Right
        if loc==B -> Left
    }

    class ModelBasedVacuumAgent <<factory>> {
        +create() : Agent
        ..
        Modelo: {loc_A: state, loc_B: state}
        if todo Clean -> NoOp
    }
}

RandomVacuumAgent       ..> Agent : <<creates>>
TableDrivenVacuumAgent  ..> Agent : <<creates>>
ReflexVacuumAgent       ..> Agent : <<creates>>
ModelBasedVacuumAgent   ..> Agent : <<creates>>

TrivialVacuumEnvironment ..> ReflexVacuumAgent      : <<accepts>>
TrivialVacuumEnvironment ..> TableDrivenVacuumAgent  : <<accepts>>
TrivialVacuumEnvironment ..> RandomVacuumAgent       : <<accepts>>
TrivialVacuumEnvironment ..> ModelBasedVacuumAgent   : <<accepts>>

' -------------------------------------------------------
' Funciones auxiliares de programas de agente
' -------------------------------------------------------

class TableDrivenAgentProgram <<function>> {
    +__call__(table) : callable
    ..
    Acumula historial de percepts
    e indexa en la tabla dada
}

class SimpleReflexAgentProgram <<function>> {
    +__call__(rules, interpret_input) : callable
    ..
    state = interpret_input(percept)
    rule  = RULE-MATCH(state, rules)
    return rule.action
}

class ModelBasedReflexAgentProgram <<function>> {
    +__call__(rules, update_state, model) : callable
    ..
    Actualiza estado con update_state()
    luego aplica RULE-MATCH
}

TableDrivenVacuumAgent  ..> TableDrivenAgentProgram         : uses
ReflexVacuumAgent       ..> SimpleReflexAgentProgram        : uses
ModelBasedVacuumAgent   ..> ModelBasedReflexAgentProgram    : uses

' -------------------------------------------------------
' Nota: ciclo de ejecución
' -------------------------------------------------------

note bottom of Environment
  Ciclo de ejecución (step):
  1. percept(agent)           -- el entorno observa al agente
  2. agent.program(percept)   -- el agente decide una acción
  3. execute_action(agent, action) -- el entorno cambia de estado
end note

@enduml
